{
  "name": "@frontend-workspace/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx dev english-app",
    "build": "nx build english-app",
    "start": "nx start english-app",
    "format": "prettier --write \"apps/**/*.{ts,tsx,scss}\" \"packages/**/*.{ts,tsx,scss}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,scss}\" \"packages/**/*.{ts,tsx,scss}\"",
    "graph": "nx graph"
  },
  "private": true,
  "devDependencies": {
    "@nx/js": "22.6.1",
    "@nx/next": "^22.6.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "nx": "22.6.1",
    "prettier": "~3.6.2",
    "sass": "^1.98.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "verdaccio": "^6.0.5"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.94.5",
    "next": "~16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
